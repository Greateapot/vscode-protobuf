{
  "name": "vscode-protobuf",
  "displayName": "Protobuf",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "proto3",
        "extensions": [
          ".proto"
        ],
        "aliases": [
          "Protocol Buffers"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "proto3",
        "scopeName": "source.proto",
        "path": "./syntaxes/proto.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "compile": "bun build src/extension.ts --outfile dist/extension.js --target=node --external vscode",
    "watch": "bun build src/extension.ts --outfile dist/extension.js --target=node --external vscode --watch",
    "package": "vsce package --no-dependencies --allow-missing-repository --out out/"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.1"
  }
}
