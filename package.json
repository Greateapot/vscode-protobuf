{
  "$schema": "vscode://schemas/vscode-extensions",
  "name": "vscode-protobuf",
  "displayName": "Protobuf",
  "description": "Protocol Buffers support for VS Code via protols",
  "version": "0.0.1",
  "publisher": "Greateapot",
  "author": {
    "name": "Greateapot",
    "url": "https://github.com/Greateapot"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Greateapot/vscode-protobuf"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "icon": "images/protobuf-logo.png",
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "proto",
        "extensions": [
          ".proto"
        ],
        "aliases": [
          "Protocol Buffers",
          "Protobuf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "proto",
        "scopeName": "source.proto",
        "path": "./syntaxes/proto.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "proto",
        "path": "./snippets/proto.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "compile": "bun build src/extension.ts --outfile dist/extension.js --target=node --platform=node --external vscode --minify",
    "watch": "bun build src/extension.ts --outfile dist/extension.js --target=node --platform=node --external vscode --watch",
    "package": "vsce package --no-dependencies --allow-missing-repository --out out/"
  }
}
